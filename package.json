{
  "name": "@koi-video/voice-realtime-sdk-beta",
  "version": "0.1.1",
  "description": "Voice realtime ChatClient: REST (realtime/voice) + Agora RTC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "sideEffects": false,
  "keywords": [
    "voice",
    "agora",
    "realtime"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "vite build --config vite.lib.config.js",
    "prepublishOnly": "vite build --config vite.lib.config.js",
    "demo": "vite --config demo/vite.config.js",
    "demo:preview": "vite preview --config demo/vite.config.js --port 5174"
  },
  "dependencies": {
    "agora-rtc-sdk-ng": "^4.24.2"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "vite": "^6.0.1"
  }
}
